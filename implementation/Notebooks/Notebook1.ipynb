    "assert os.path.exists(ITGC_PATH), f\"❌ ITGC file not found at: {ITGC_PATH}\"\n",
    "assert os.path.exists(ISO_PATH),  f\"❌ ISO file not found at: {ISO_PATH}\"\n",
    "print(\"✅ Both source files found\")"
