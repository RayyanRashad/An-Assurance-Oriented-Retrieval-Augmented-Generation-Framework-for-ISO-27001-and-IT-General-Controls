    "import pandas as pd\n",
    "\n",
    "def load_itgc_excel(path: str) -> list[dict]:\n",
    "    \"\"\"\n",
    "    Load all sheets from the ITGC Excel file.\n",
    "    Returns a flat list of control dicts with normalized fields.\n",
    "    Each dict has: source, domain, control_id, control_area,\n",
    "                   what_auditor_reviews, evidence, raw_text\n",
    "    \"\"\"\n",
    "    xl = pd.ExcelFile(path)\n",
    "    all_controls = []\n",
    "\n",
    "    for sheet_name in xl.sheet_names:\n",
    "        df = xl.parse(sheet_name)\n",
    "        df.columns = [str(c).strip() for c in df.columns]  # normalize column names\n",
    "\n",
    "        print(f\"\\n📄 Sheet: '{sheet_name}' | Rows: {len(df)} | Columns: {list(df.columns)}\")\n",
    "\n",
    "        for _, row in df.iterrows():\n",
    "            # Skip rows where S.N is not a valid integer (headers, empty rows)\n",
    "            try:\n",
    "                sn = int(row.iloc[0])\n",
    "            except (ValueError, TypeError):\n",
    "                continue\n",
    "\n",
    "            # Flexibly extract columns regardless of sheet format\n",
    "            control_area          = str(row.iloc[1]).strip() if len(row) > 1 else \"\"\n",
    "            what_auditor_reviews  = str(row.iloc[2]).strip() if len(row) > 2 else \"\"\n",
    "            evidence              = str(row.iloc[3]).strip() if len(row) > 3 else \"\"\n",
    "\n",
    "            # Clean up 'nan' strings from empty cells\n",
    "            what_auditor_reviews = \"\" if what_auditor_reviews == \"nan\" else what_auditor_reviews\n",
    "            evidence             = \"\" if evidence == \"nan\" else evidence\n",
    "\n",
    "            # Build a human-readable chunk text — this is what gets embedded\n",
    "            raw_text_parts = [\n",
    "                f\"Domain: {sheet_name.strip()}\",\n",
    "                f\"Control Area: {control_area}\",\n",
    "            ]\n",
    "            if what_auditor_reviews:\n",
    "                raw_text_parts.append(f\"What Auditor Reviews: {what_auditor_reviews}\")\n",
    "            if evidence:\n",
    "                raw_text_parts.append(f\"Evidence / Key Checks: {evidence}\")\n",
    "\n",
    "            all_controls.append({\n",
    "                \"source\":               \"ITGC\",\n",
    "                \"domain\":               sheet_name.strip(),\n",
    "                \"control_id\":           f\"ITGC-{sheet_name.strip()[:3].upper()}-{sn:02d}\",\n",
    "                \"control_area\":         control_area,\n",
    "                \"what_auditor_reviews\": what_auditor_reviews,\n",
    "                \"evidence\":             evidence,\n",
    "                \"raw_text\":             \"\\n\".join(raw_text_parts),\n",
    "            })\n",
    "\n",
    "    return all_controls\n",
    "\n",
    "\n",
    "itgc_controls = load_itgc_excel(ITGC_PATH)\n",
    "print(f\"\\n✅ Total ITGC controls loaded: {len(itgc_controls)}\")"
   ]
  },
