   "source": [
    "import re\n",
    "\n",
    "def parse_iso_clauses(pages: list[dict]) -> list[dict]:\n",
    "    \"\"\"\n",
    "    Split ISO 27001 page text into clause-level chunks.\n",
    "\n",
    "    Strategy:\n",
    "    - Concatenate all page text with page markers\n",
    "    - Split on numbered clause headings (e.g. '4.1', '6.1.2', 'A.5.1')\n",
    "    - Each chunk gets: clause_id, clause_title, page_ref, text, source metadata\n",
    "    \"\"\"\n",
    "\n",
    "    # Combine all pages into one string with page markers\n",
    "    full_text = \"\"\n",
    "    page_map = {}  # track which character offset maps to which page\n",
    "    for p in pages:\n",
    "        page_map[len(full_text)] = p['page_number']\n",
    "        full_text += f\"\\n\\n[PAGE {p['page_number']}]\\n\" + p['text']\n",
    "\n",
    "    # Regex to detect clause headings like: '4 Context', '6.1.2 Information security',\n",
    "    # '5.1 Leadership', 'A.5 Organizational', etc.\n",
    "    clause_pattern = re.compile(\n",
    "        r'(?m)^(\\d+(?:\\.\\d+){0,2}|A\\.\\d+(?:\\.\\d+)?)\\s+([A-Z][\\w,\\s\\/\\(\\)\\-]{3,80})$'\n",
    "    )\n",
    "\n",
    "    matches = list(clause_pattern.finditer(full_text))\n",
    "    print(f\"Found {len(matches)} clause headings in PDF\")\n",
    "\n",
    "    chunks = []\n",
    "    for i, match in enumerate(matches):\n",
    "        clause_id    = match.group(1).strip()\n",
    "        clause_title = match.group(2).strip()\n",
    "\n",
    "        # Skip front matter (clauses 1-3 are just scope/references/definitions)\n",
    "        # Keep clauses 4-10 and Annex A\n",
    "        top_level = clause_id.split('.')[0]\n",
    "        if top_level.isdigit() and int(top_level) < 4:\n",
    "            continue\n",
    "\n",
    "        # Text is from this match to the next match\n",
    "        start = match.start()\n",
    "        end   = matches[i + 1].start() if i + 1 < len(matches) else len(full_text)\n",
    "        chunk_text = full_text[start:end].strip()\n",
    "\n",
    "        # Find the page number at this position\n",
    "        page_ref = 1\n",
    "        for offset, pg in sorted(page_map.items()):\n",
    "            if offset <= start:\n",
    "                page_ref = pg\n",
    "\n",
    "        # Determine if this is Annex A (controls) or main body (requirements)\n",
    "        section_type = \"annex_a_control\" if clause_id.startswith(\"A.\") or (\n",
    "            top_level.isdigit() and int(top_level) > 10\n",
    "        ) else \"main_clause\"\n",
    "\n",
    "        # Determine Annex A domain label\n",
    "        annex_domain = None\n",
    "        if section_type == \"annex_a_control\":\n",
    "            domain_map = {\"5\": \"Organizational\", \"6\": \"People\", \"7\": \"Physical\", \"8\": \"Technological\"}\n",
    "            for k, v in domain_map.items():\n",
    "                if clause_id.startswith(k + \".\") or clause_id == k:\n",
    "                    annex_domain = v\n",
    "\n",
    "        chunks.append({\n",
    "            \"source\":        \"ISO27001\",\n",
    "            \"clause_id\":     clause_id,\n",
    "            \"clause_title\":  clause_title,\n",
    "            \"section_type\":  section_type,\n",
    "            \"annex_domain\":  annex_domain,\n",
    "            \"page_ref\":      page_ref,\n",
    "            \"raw_text\":      chunk_text,\n",
    "            \"control_id\":    f\"ISO-{clause_id}\",\n",
    "        })\n",
    "\n",
    "    return chunks\n",
    "\n",
    "\n",
    "iso_chunks = parse_iso_clauses(iso_pages)\n",
    "print(f\"\\n✅ Total ISO 27001 chunks parsed: {len(iso_chunks)}\")"
   ]
  },
