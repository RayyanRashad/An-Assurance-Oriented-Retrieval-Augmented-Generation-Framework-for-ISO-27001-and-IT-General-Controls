   "source": [
    "## Fix 2 — Re-tag Annex A controls correctly\n",
    "\n",
    "Annex A controls in this PDF use bare clause IDs like `5.1`, `6.2`, `8.15` — NOT `A.5.1`.  \n",
    "A clause is an Annex A control if **all three** conditions hold:\n",
    "- It is an ISO document\n",
    "- Its clause_id top-level is 5, 6, 7, or 8\n",
    "- Its `raw_text` contains the word `Control` (the PDF table header pattern)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "0949f27b-e003-45e6-aa82-73a777109929",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Re-tagged 92 documents as annex_a_control\n",
      "\n",
      "ISO section_type breakdown after fix:\n",
      "  main_clause: 44\n",
      "  annex_a_control: 92\n",
      "\n",
      "Annex A domain breakdown after fix:\n",
      "  Physical: 13\n",
      "  Organizational: 37\n",
      "  People: 8\n",
      "  Technological: 34\n"
     ]
    }
   ],
   "source": [
    "# Annex A domain mapping based on top-level clause number\n",
    "ANNEX_DOMAIN_MAP = {\n",
    "    \"5\": \"Organizational\",\n",
    "    \"6\": \"People\",\n",
    "    \"7\": \"Physical\",\n",
    "    \"8\": \"Technological\",\n",
    "}\n",
    "\n",
    "retagged = 0\n",
    "\n",
    "for doc in documents:\n",
    "    if doc['source'] != 'ISO27001':\n",
    "        continue\n",
    "\n",
    "    clause_id = doc['metadata'].get('clause_id', '')\n",
    "    top_level = clause_id.split('.')[0]\n",
    "\n",
    "    is_annex_range   = top_level in ANNEX_DOMAIN_MAP\n",
    "    has_control_word = 'Control' in doc['raw_text']\n",
    "    currently_wrong  = doc['metadata'].get('section_type') != 'annex_a_control'\n",
    "\n",
    "    if is_annex_range and has_control_word and currently_wrong:\n",
    "        doc['metadata']['section_type'] = 'annex_a_control'\n",
    "        doc['metadata']['annex_domain'] = ANNEX_DOMAIN_MAP[top_level]\n",
    "        doc['domain'] = ANNEX_DOMAIN_MAP[top_level]\n",
    "        retagged += 1\n",
    "\n",
    "print(f\"Re-tagged {retagged} documents as annex_a_control\")\n",
    "\n",
    "# Verify\n",
    "from collections import Counter\n",
    "iso_docs = [d for d in documents if d['source'] == 'ISO27001']\n",
    "print(f\"\\nISO section_type breakdown after fix:\")\n",
    "for k, v in Counter(d['metadata']['section_type'] for d in iso_docs).items():\n",
    "    print(f\"  {k}: {v}\")\n",
    "\n",
    "print(f\"\\nAnnex A domain breakdown after fix:\")\n",
    "annex_docs = [d for d in iso_docs if d['metadata']['section_type'] == 'annex_a_control']\n",
    "for k, v in Counter(d['domain'] for d in annex_docs).items():\n",
    "    print(f\"  {k}: {v}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cc9d4cbc-face-43a7-ab41-0935a12fb673",
   "metadata": {},
   "source": [
    "## Fix 3 — Clean clause title artifacts\n",
    "\n",
    "Some titles have PDF extraction artifacts:\n",
    "- Hyphenated line breaks: `require -\\nments` → `requirements`\n",
    "- Trailing `Control` word bled in from the table: `Secure coding Control` → `Secure coding`\n",
    "- Stray newlines mid-title"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "f4358fc3-7fbe-4caf-be03-533f52d2c4a9",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Cleaned 91 clause titles\n",
      "\n",
      "Sample cleaned titles:\n",
      "  Before: 'Application security require -\\nments\\nControl'\n",
      "  After : 'Application security require ments'\n",
      "\n",
      "  Before: 'Secure system architecture and \\nengineering princi'\n",
      "  After : 'Secure system architecture and engineering princi'\n",
      "\n",
      "  Before: 'Security testing in development \\nand acceptance\\nCo'\n",
      "  After : 'Security testing in development and acceptance Co'\n",
      "\n"
     ]
    }
   ],
   "source": [
    "def clean_clause_title(title: str) -> str:\n",
    "    # Fix hyphenated line breaks: 'require -\\nments' -> 'requirements'\n",
    "    title = re.sub(r'-\\s*\\n\\s*', '', title)\n",
    "    # Remove stray newlines\n",
    "    title = re.sub(r'\\n+', ' ', title)\n",
    "    # Remove trailing 'Control' word that bled in from the table format\n",
    "    title = re.sub(r'\\s*\\bControl\\b\\s*$', '', title, flags=re.IGNORECASE)\n",
    "    # Collapse multiple spaces\n",
    "    title = re.sub(r' {2,}', ' ', title)\n",
    "    return title.strip()\n",
    "\n",
    "\n",
    "cleaned = 0\n",
    "for doc in documents:\n",
    "    if doc['source'] != 'ISO27001':\n",
    "        continue\n",
    "    original = doc['metadata'].get('clause_title', '')\n",
    "    fixed    = clean_clause_title(original)\n",
    "    if fixed != original:\n",
    "        doc['metadata']['clause_title'] = fixed\n",
    "        cleaned += 1\n",
    "\n",
    "print(f\"Cleaned {cleaned} clause titles\")\n",
    "\n",
    "# Show a few before/after examples\n",
    "print(\"\\nSample cleaned titles:\")\n",
    "examples = [\n",
    "    \"Application security require -\\nments\\nControl\",\n",
    "    \"Secure system architecture and \\nengineering princi\",\n",
    "    \"Security testing in development \\nand acceptance\\nCo\",\n",
    "]\n",
    "for ex in examples:\n",
    "    print(f\"  Before: {repr(ex)}\")\n",
    "    print(f\"  After : {repr(clean_clause_title(ex))}\")\n",
    "    print()"
   ]
  },
