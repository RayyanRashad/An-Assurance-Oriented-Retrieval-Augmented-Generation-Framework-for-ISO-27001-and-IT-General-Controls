   "metadata": {},
   "source": [
    "## 3.1 Load All Artifacts"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 44,
   "id": "5ab840fa-8c1c-4f8a-a004-b5c403cacad6",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "application/vnd.jupyter.widget-view+json": {
