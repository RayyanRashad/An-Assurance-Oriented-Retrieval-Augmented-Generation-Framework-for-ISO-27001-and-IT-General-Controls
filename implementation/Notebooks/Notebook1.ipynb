    "## 1.5 Combine Into a Unified Document Store\n",
    "\n",
    "We now have two parsed lists. We merge them into a single flat list called `document_store`.  \n",
    "Every document in this store has a consistent schema:\n",
    "\n",
    "| Field | Description |\n",
    "|---|---|\n",
    "| `doc_id` | Unique identifier across all documents |\n",
    "| `source` | `\"ITGC\"` or `\"ISO27001\"` |\n",
    "| `control_id` | Human-readable ID (e.g., `ITGC-ACC-01`, `ISO-6.1.2`) |\n",
    "| `domain` | Domain/sheet/clause group |\n",
    "| `raw_text` | The text that will be embedded and retrieved |\n",
    "| `metadata` | Dict of all other fields for display in results |"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "25786615-2001-4cb2-8344-d69c45cc64c1",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Unified document store built\n",
      "   Total documents : 174\n",
      "   ITGC documents  : 37\n",
      "   ISO documents   : 137\n"
     ]
    }
   ],
   "source": [
    "def build_document_store(\n",
    "    itgc_controls: list[dict],\n",
    "    iso_chunks: list[dict]\n",
    ") -> list[dict]:\n",
    "    \"\"\"\n",
    "    Normalize ITGC controls and ISO chunks into a unified document store.\n",
    "    Each entry has: doc_id, source, control_id, domain, raw_text, metadata\n",
    "    \"\"\"\n",
    "    store = []\n",
    "\n",
    "    # --- ITGC documents ---\n",
    "    for i, ctrl in enumerate(itgc_controls):\n",
    "        store.append({\n",
    "            \"doc_id\":     f\"itgc_{i:03d}\",\n",
    "            \"source\":     \"ITGC\",\n",
    "            \"control_id\": ctrl[\"control_id\"],\n",
    "            \"domain\":     ctrl[\"domain\"],\n",
    "            \"raw_text\":   ctrl[\"raw_text\"],\n",
    "            \"metadata\": {\n",
    "                \"control_area\":         ctrl[\"control_area\"],\n",
    "                \"what_auditor_reviews\": ctrl[\"what_auditor_reviews\"],\n",
    "                \"evidence\":             ctrl[\"evidence\"],\n",
    "            }\n",
    "        })\n",
    "\n",
    "    # --- ISO 27001 documents ---\n",
    "    for i, chunk in enumerate(iso_chunks):\n",
    "        store.append({\n",
    "            \"doc_id\":     f\"iso_{i:03d}\",\n",
    "            \"source\":     \"ISO27001\",\n",
    "            \"control_id\": chunk[\"control_id\"],\n",
    "            \"domain\":     chunk.get(\"annex_domain\") or f\"Clause {chunk['clause_id'].split('.')[0]}\",\n",
    "            \"raw_text\":   chunk[\"raw_text\"],\n",
    "            \"metadata\": {\n",
    "                \"clause_id\":    chunk[\"clause_id\"],\n",
    "                \"clause_title\": chunk[\"clause_title\"],\n",
    "                \"section_type\": chunk[\"section_type\"],\n",
    "                \"page_ref\":     chunk[\"page_ref\"],\n",
    "            }\n",
    "        })\n",
    "\n",
    "    return store\n",
    "\n",
    "\n",
    "document_store = build_document_store(itgc_controls, iso_chunks)\n",
    "\n",
    "print(f\"✅ Unified document store built\")\n",
    "print(f\"   Total documents : {len(document_store)}\")\n",
    "print(f\"   ITGC documents  : {sum(1 for d in document_store if d['source'] == 'ITGC')}\")\n",
    "print(f\"   ISO documents   : {sum(1 for d in document_store if d['source'] == 'ISO27001')}\")"
   ]
  },
