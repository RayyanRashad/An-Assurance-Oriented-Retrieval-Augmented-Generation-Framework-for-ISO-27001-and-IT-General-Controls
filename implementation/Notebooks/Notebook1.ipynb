   "source": [
    "## 2.5 Build BM25 Index\n",
    "\n",
    "BM25 operates on tokenized text. We do minimal tokenization: lowercase, split on whitespace and punctuation.  \n",
    "No stemming — audit terms like `authentication`, `cryptography` should stay intact."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 29,
   "id": "62cc5f20-a7f7-47bc-ab53-812c80bd71b7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ BM25 index built\n",
      "   Corpus size    : 158 documents\n",
      "   Avg doc length : 42.5 tokens\n",
      "\n",
      "Smoke test (BM25: \"access control user provisioning\"):\n",
      "  Rank 1: score=9.494 | ITGC-ACC-07 | ITGC | Access Management\n",
      "  Rank 2: score=6.887 | ITGC-COM-05 | ITGC | Computer Operation\n",
      "  Rank 3: score=6.710 | ITGC-ACC-05 | ITGC | Access Management\n",
      "  Rank 4: score=6.629 | ITGC-ACC-06 | ITGC | Access Management\n",
      "  Rank 5: score=6.376 | ISO-8.1 | ISO27001 | Technological\n"
     ]
    }
   ],
   "source": [
    "import re\n",
    "from rank_bm25 import BM25Okapi\n",
    "\n",
    "def tokenize(text: str) -> list[str]:\n",
    "    \"\"\"Lowercase and split on non-alphanumeric characters.\"\"\"\n",
    "    return re.findall(r'[a-z0-9]+', text.lower())\n",
    "\n",
    "tokenized_corpus = [tokenize(doc['raw_text']) for doc in documents]\n",
    "bm25_index = BM25Okapi(tokenized_corpus)\n",
    "\n",
    "print(f'✅ BM25 index built')\n",
    "print(f'   Corpus size    : {len(tokenized_corpus)} documents')\n",
    "print(f'   Avg doc length : {sum(len(t) for t in tokenized_corpus) / len(tokenized_corpus):.1f} tokens')\n",
    "\n",
    "# Smoke test — search for 'access control'\n",
    "test_query_tokens = tokenize('access control user provisioning')\n",
    "bm25_scores = bm25_index.get_scores(test_query_tokens)\n",
    "top5_idx = np.argsort(bm25_scores)[::-1][:5]\n",
    "print(f'\\nSmoke test (BM25: \"access control user provisioning\"):')\n",
    "for rank, idx in enumerate(top5_idx):\n",
    "    print(f'  Rank {rank+1}: score={bm25_scores[idx]:.3f} | {documents[idx][\"control_id\"]} | {documents[idx][\"source\"]} | {documents[idx][\"domain\"]}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "5954310a-9d3c-4108-9ebd-6ee297a0b6b9",
   "metadata": {
    "jp-MarkdownHeadingCollapsed": true
   },
   "source": [
    "## 2.6 Reciprocal Rank Fusion (RRF)\n",
    "\n",
    "RRF combines the ranked lists from FAISS and BM25 into a single score.  \n",
    "Formula: `RRF(d) = Σ 1 / (k + rank(d))` where k=60 is a smoothing constant.\n",
    "\n",
    "We define the full hybrid retrieval function here and test it."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 31,
   "id": "ead7448f-3f30-417b-a32a-3834ab9ecea8",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ hybrid_search() defined\n"
     ]
    }
   ],
   "source": [
    "def hybrid_search(\n",
    "    query: str,\n",
    "    documents: list[dict],\n",
    "    faiss_index,\n",
    "    bm25_index,\n",
    "    model,\n",
    "    top_k: int = 5,\n",
    "    rrf_k: int = 60,\n",
    "    source_filter: str = None,   # 'ITGC', 'ISO27001', or None for both\n",
    ") -> list[dict]:\n",
    "    \"\"\"\n",
    "    Hybrid retrieval: FAISS dense + BM25 sparse, fused with RRF.\n",
    "\n",
    "    Args:\n",
    "        query         : Natural language query string\n",
    "        documents     : The full document list (same order as index)\n",
    "        faiss_index   : Built FAISS index\n",
    "        bm25_index    : Built BM25Okapi index\n",
    "        model         : SentenceTransformer model\n",
    "        top_k         : Number of results to return\n",
    "        rrf_k         : RRF smoothing constant (default 60)\n",
    "        source_filter : Optionally restrict results to one source\n",
    "\n",
    "    Returns:\n",
    "        List of dicts: document + rrf_score + faiss_rank + bm25_rank\n",
    "    \"\"\"\n",
    "    n = len(documents)\n",
    "\n",
    "    # --- Dense retrieval (FAISS) ---\n",
    "    query_embedding = model.encode(\n",
    "        [BGE_QUERY_PREFIX + query],\n",
    "        normalize_embeddings=True,\n",
    "        convert_to_numpy=True,\n",
    "    ).astype(np.float32)\n",
    "\n",
    "    faiss_scores, faiss_indices = faiss_index.search(query_embedding, k=n)\n",
    "    faiss_ranks = {int(idx): rank for rank, idx in enumerate(faiss_indices[0])}\n",
    "\n",
    "    # --- Sparse retrieval (BM25) ---\n",
    "    bm25_scores_all = bm25_index.get_scores(tokenize(query))\n",
    "    bm25_order = np.argsort(bm25_scores_all)[::-1]\n",
    "    bm25_ranks = {int(idx): rank for rank, idx in enumerate(bm25_order)}\n",
    "\n",
    "    # --- RRF fusion ---\n",
    "    rrf_scores = {}\n",
    "    for idx in range(n):\n",
    "        r_faiss = faiss_ranks.get(idx, n)\n",
    "        r_bm25  = bm25_ranks.get(idx, n)\n",
    "        rrf_scores[idx] = (1 / (rrf_k + r_faiss)) + (1 / (rrf_k + r_bm25))\n",
    "\n",
    "    # Sort by RRF score descending\n",
    "    ranked = sorted(rrf_scores.items(), key=lambda x: x[1], reverse=True)\n",
    "\n",
    "    # --- Build result list ---\n",
    "    results = []\n",
    "    for idx, score in ranked:\n",
    "        doc = documents[idx]\n",
    "        if source_filter and doc['source'] != source_filter:\n",
    "            continue\n",
    "        results.append({\n",
    "            **doc,\n",
    "            'rrf_score':  round(score, 6),\n",
    "            'faiss_rank': faiss_ranks.get(idx, n),\n",
    "            'bm25_rank':  bm25_ranks.get(idx, n),\n",
    "        })\n",
    "        if len(results) >= top_k:\n",
    "            break\n",
    "\n",
    "    return results\n",
    "\n",
    "print('✅ hybrid_search() defined')"
   ]
  },
