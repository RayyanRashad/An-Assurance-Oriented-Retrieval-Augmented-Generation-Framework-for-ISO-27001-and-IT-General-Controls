    "\n",
    "print(f\"\\nFinal breakdown:\")\n",
    "from collections import Counter\n",
    "src_counts = Counter(d['source'] for d in documents)\n",
    "for k, v in src_counts.items():\n",
    "    print(f\"  {k}: {v}\")"
