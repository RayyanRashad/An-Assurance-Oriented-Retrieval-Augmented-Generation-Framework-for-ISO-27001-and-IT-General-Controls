    "        print(f\"Fixed: ISO-7.5.3 → main_clause, domain=Clause 7\")\n",
    "\n",
    "# --- Fix B: Remove section-header-only docs (< 50 chars, no real content) ---\n",
    "# These are bare headings like '5 Leadership' or '7 Physical controls'\n",
    "# They add noise to retrieval without contributing information\n",
    "before = len(documents)\n",
    "documents = [d for d in documents if len(d['raw_text'].strip()) >= 50]\n",
    "removed = before - len(documents)\n",
    "print(f\"Removed {removed} header-only documents (< 50 chars)\")\n",
    "print(f\"Documents ready for indexing: {len(documents)}\")\n",
    "\n",
    "# Reassign sequential doc_ids to keep them clean after removals\n",
    "for i, doc in enumerate(documents):\n",
