    "import json\n",
    "import os\n",
    "import pickle\n",
    "import re\n",
    "import numpy as np\n",
    "import faiss\n",
    "from rank_bm25 import BM25Okapi\n",
    "from sentence_transformers import SentenceTransformer\n",
    "import anthropic\n",
    "from dotenv import load_dotenv\n",
    "\n",
    "load_dotenv()\n",
    "\n",
    "# --- Load documents ---\n",
    "with open('indexed_documents.json', 'r', encoding='utf-8') as f:\n",
    "    documents = json.load(f)\n",
    "\n",
    "# --- Load FAISS index ---\n",
    "faiss_index = faiss.read_index('faiss_index.bin')\n",
    "\n",
    "# --- Load BM25 index ---\n",
    "with open('bm25_index.pkl', 'rb') as f:\n",
    "    bm25_payload = pickle.load(f)\n",
    "bm25_index        = bm25_payload['bm25']\n",
    "tokenized_corpus  = bm25_payload['tokenized_corpus']\n",
    "\n",
    "# --- Load embedding model ---\n",
    "MODEL_NAME       = 'BAAI/bge-small-en-v1.5'\n",
    "BGE_QUERY_PREFIX = 'Represent this sentence for searching relevant passages: '\n",
    "embed_model      = SentenceTransformer(MODEL_NAME)\n",
    "\n",
    "from groq import Groq\n",
    "client = Groq(api_key=\"enter key")\n",
    "\n",
    "print(f'✅ All artifacts loaded')\n",
    "print(f'   Documents : {len(documents)}')\n",
    "print(f'   FAISS     : {faiss_index.ntotal} vectors')\n",
    "print(f'   BM25      : {len(tokenized_corpus)} docs')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "da3356a7-dc56-4e4f-a553-6aa23aa2fd04",
   "metadata": {},
   "source": [
    "## 3.2 Retrieval Helpers\n",
    "\n",
    "Copied from Step 2 so this notebook is self-contained."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 38,
   "id": "10ae4db9-bc94-4ad6-aaa1-fab8fda6505c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Retrieval helpers defined\n"
     ]
    }
   ],
   "source": [
    "def tokenize(text: str) -> list[str]:\n",
    "    return re.findall(r'[a-z0-9]+', text.lower())\n",
    "\n",
    "\n",
    "def hybrid_search(\n",
    "    query: str,\n",
    "    top_k: int = 6,\n",
    "    rrf_k: int = 60,\n",
    "    source_filter: str = None,\n",
    ") -> list[dict]:\n",
    "    n = len(documents)\n",
    "\n",
    "    # Dense retrieval\n",
    "    q_emb = embed_model.encode(\n",
    "        [BGE_QUERY_PREFIX + query],\n",
    "        normalize_embeddings=True,\n",
    "        convert_to_numpy=True,\n",
    "    ).astype(np.float32)\n",
    "    faiss_scores, faiss_indices = faiss_index.search(q_emb, k=n)\n",
    "    faiss_ranks = {int(idx): rank for rank, idx in enumerate(faiss_indices[0])}\n",
    "\n",
    "    # Sparse retrieval\n",
    "    bm25_scores_all = bm25_index.get_scores(tokenize(query))\n",
    "    bm25_order      = np.argsort(bm25_scores_all)[::-1]\n",
    "    bm25_ranks      = {int(idx): rank for rank, idx in enumerate(bm25_order)}\n",
    "\n",
    "    # RRF fusion\n",
    "    rrf_scores = {\n",
    "        idx: (1 / (rrf_k + faiss_ranks.get(idx, n))) + (1 / (rrf_k + bm25_ranks.get(idx, n)))\n",
    "        for idx in range(n)\n",
    "    }\n",
    "    ranked = sorted(rrf_scores.items(), key=lambda x: x[1], reverse=True)\n",
    "\n",
    "    results = []\n",
    "    for idx, score in ranked:\n",
    "        doc = documents[idx]\n",
    "        if source_filter and doc['source'] != source_filter:\n",
    "            continue\n",
    "        results.append({**doc, 'rrf_score': round(score, 6)})\n",
    "        if len(results) >= top_k:\n",
    "            break\n",
    "\n",
    "    return results\n",
    "\n",
    "\n",
    "def format_context_block(docs: list[dict]) -> str:\n",
    "    \"\"\"\n",
    "    Format retrieved documents into a numbered context block for the LLM prompt.\n",
    "    Each document is clearly labeled with its ID and source.\n",
    "    \"\"\"\n",
    "    lines = []\n",
    "    for i, doc in enumerate(docs):\n",
    "        title = (\n",
    "            doc['metadata'].get('clause_title') or\n",
    "            doc['metadata'].get('control_area') or\n",
    "            doc['domain']\n",
    "        )\n",
    "        lines.append(\n",
    "            f\"[{i+1}] SOURCE: {doc['source']} | ID: {doc['control_id']} | \"\n",
    "            f\"DOMAIN: {doc['domain']} | TITLE: {title}\\n\"\n",
    "            f\"{doc['raw_text'].strip()}\"\n",
    "        )\n",
    "    return \"\\n\\n---\\n\\n\".join(lines)\n",
    "\n",
    "\n",
    "print('✅ Retrieval helpers defined')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2d31d5e7-168b-4cf8-8cd6-0fda74a4cc84",
   "metadata": {},
   "source": [
    "## 3.3 Prompt Templates\n",
    "\n",
    "Each query mode has a dedicated system prompt. The key constraint in all three:\n",
    "- Answer **only** from the provided context documents\n",
    "- Every claim must cite a document using its `[N]` reference number\n",
    "- If the context does not support the answer, say so explicitly — do not fill gaps with general knowledge"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 40,
   "id": "4cc98f5b-7949-481a-a6f4-489e39106145",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Prompt templates defined\n"
     ]
    }
   ],
   "source": [
    "SYSTEM_PROMPTS = {\n",
    "\n",
    "    'general': \"\"\"\\\n",
    "You are a senior IT audit specialist with deep expertise in ISO 27001:2022 and ITGC (IT General Controls).\n",
    "You answer auditor questions strictly based on the context documents provided.\n",
    "\n",
    "RULES:\n",
    "1. Base every statement on the provided context documents only.\n",
    "2. Cite sources using [N] notation matching the document number in the context.\n",
    "3. If the context does not contain enough information to answer fully, explicitly state what is missing.\n",
    "4. Do not add knowledge from outside the provided context.\n",
    "5. Be precise and professional — this output may be used in a real audit.\n",
    "\n",
    "FORMAT:\n",
    "- Answer: A clear, direct response with inline [N] citations\n",
    "- Evidence Sources: Numbered list of cited documents (ID, source, title)\n",
    "- Gaps: Any aspects of the question not covered by the retrieved context\"\"\",\n",
    "\n",
    "    'compliance_check': \"\"\"\\\n",
    "You are a senior IT audit specialist conducting a compliance gap analysis between ITGC controls and ISO 27001:2022.\n",
    "You evaluate whether controls described in the context documents satisfy a stated requirement.\n",
    "\n",
    "RULES:\n",
    "1. Only use the provided context documents as evidence.\n",
    "2. Cite every finding with [N] notation.\n",
    "3. Be conservative — partial coverage is NOT full compliance.\n",
    "4. Do not infer compliance from general knowledge.\n",
    "\n",
    "FORMAT:\n",
    "- Verdict: COVERED / PARTIALLY COVERED / NOT COVERED\n",
    "- Reasoning: Step-by-step analysis with [N] citations\n",
    "- Covered By: List of controls that address the requirement (ID + title)\n",
    "- Gaps: Specific requirements not addressed by any retrieved control\"\"\",\n",
    "\n",
    "    'cross_mapping': \"\"\"\\\n",
    "You are a senior IT audit specialist performing a cross-framework control mapping between ITGC and ISO 27001:2022.\n",
    "Your job is to identify which ITGC controls align with which ISO 27001 controls, and surface any gaps.\n",
    "\n",
    "RULES:\n",
    "1. Only map controls that appear in the provided context documents.\n",
    "2. Cite every mapping with [N] notation from both sources.\n",
    "3. A mapping is STRONG if both controls share objective AND method.\n",
    "4. A mapping is PARTIAL if they share objective but differ in scope or method.\n",
    "5. Do not invent mappings not supported by the context.\n",
    "\n",
    "FORMAT:\n",
    "- Mappings: Table-style list of ITGC control → ISO 27001 control → Alignment (Strong/Partial)\n",
    "- Reasoning: Brief justification per mapping with [N] citations\n",
    "- ITGC Gaps: ITGC controls with no ISO 27001 equivalent in the context\n",
    "- ISO Gaps: ISO 27001 controls with no ITGC equivalent in the context\"\"\",\n",
    "}\n",
    "\n",
    "print('✅ Prompt templates defined')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "55106faf-9179-4e5b-81c8-63911b0c77ca",
   "metadata": {},
   "source": [
    "## 3.4 Core RAG Pipeline Function"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 45,
   "id": "f76df258-3e81-4634-95a4-9e1b00e44085",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ rag_query() and print_response() defined\n"
     ]
    }
   ],
   "source": [
    "def rag_query(\n",
    "    query: str,\n",
    "    mode: str = 'general',\n",
    "    top_k: int = 6,\n",
    "    source_filter: str = None,\n",
    "    verbose: bool = True,\n",
    ") -> dict:\n",
    "    \"\"\"\n",
    "    Full RAG pipeline: retrieve → format context → generate grounded response.\n",
    "\n",
    "    Args:\n",
    "        query         : The auditor's question\n",
    "        mode          : 'general' | 'compliance_check' | 'cross_mapping'\n",
    "        top_k         : Number of documents to retrieve\n",
    "        source_filter : 'ITGC' | 'ISO27001' | None\n",
    "        verbose       : Print retrieved docs before generating\n",
    "\n",
    "    Returns:\n",
    "        dict with keys: query, mode, retrieved_docs, response, citations\n",
    "    \"\"\"\n",
    "    assert mode in SYSTEM_PROMPTS, f\"mode must be one of {list(SYSTEM_PROMPTS.keys())}\"\n",
    "\n",
    "    # --- Step 1: Retrieve ---\n",
    "    retrieved = hybrid_search(query, top_k=top_k, source_filter=source_filter)\n",
    "\n",
    "    if verbose:\n",
    "        print(f'Retrieved {len(retrieved)} documents:')\n",
    "        for i, doc in enumerate(retrieved):\n",
    "            title = doc['metadata'].get('clause_title') or doc['metadata'].get('control_area') or doc['domain']\n",
    "            print(f'  [{i+1}] {doc[\"source\"]:10} | {doc[\"control_id\"]:15} | {title}')\n",
    "        print()\n",
    "\n",
    "    # --- Step 2: Format context ---\n",
    "    context_block = format_context_block(retrieved)\n",
    "\n",
    "    user_message = f\"\"\"CONTEXT DOCUMENTS:\n",
    "{context_block}\n",
    "\n",
    "---\n",
    "\n",
    "QUESTION: {query}\"\"\"\n",
    "\n",
    "    # --- Step 3: Generate ---\n",
    "    response = client.chat.completions.create(\n",
    "        model='llama-3.3-70b-versatile',\n",
    "        max_tokens=1500,\n",
    "        messages=[\n",
    "            {'role': 'system', 'content': SYSTEM_PROMPTS[mode]},\n",
    "            {'role': 'user',   'content': user_message}\n",
    "        ],\n",
    "    )\n",
    "    answer_text = response.choices[0].message.content\n",
    "\n",
    "    # --- Step 4: Extract citation numbers from response ---\n",
    "    cited_nums = sorted(set(int(n) for n in re.findall(r'\\[(\\d+)\\]', answer_text)))\n",
    "    citations  = [\n",
    "        {\n",
    "            'ref':        n,\n",
    "            'control_id': retrieved[n-1]['control_id'],\n",
    "            'source':     retrieved[n-1]['source'],\n",
    "            'title':      retrieved[n-1]['metadata'].get('clause_title') or\n",
    "                          retrieved[n-1]['metadata'].get('control_area'),\n",
    "            'domain':     retrieved[n-1]['domain'],\n",
    "        }\n",
    "        for n in cited_nums if 1 <= n <= len(retrieved)\n",
    "    ]\n",
    "\n",
    "    return {\n",
