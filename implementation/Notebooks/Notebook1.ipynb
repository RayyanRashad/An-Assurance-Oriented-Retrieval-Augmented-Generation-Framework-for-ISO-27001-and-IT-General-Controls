    "print(\"✅ API key loaded\")\n",
    "\n",
    "# --- File Paths ---\n",
    "# Update these to match where you saved the files\n",
    "ITGC_PATH = \"/Users/mikramasharaf/Desktop/mine/dissertations/Rayyan/implementation/dataset/Check list-Rayan.xlsx\"\n",
    "ISO_PATH  = \"/Users/mikramasharaf/Desktop/mine/dissertations/Rayyan/implementation/dataset/ISO IEC 27001-2022.pdf\"\n",
