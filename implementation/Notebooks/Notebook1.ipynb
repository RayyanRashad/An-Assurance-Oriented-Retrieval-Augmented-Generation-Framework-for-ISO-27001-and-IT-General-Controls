   "source": [
    "## 2.3 Generate Embeddings\n",
    "\n",
    "We embed the `raw_text` of every document.  \n",
    "Documents are embedded without the query prefix (prefix is only used at query time)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 27,
   "id": "69d6ce86-0ef8-4c87-a4ac-142b1f8ddd32",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Encoding 158 documents...\n"
     ]
    },
    {
     "data": {
      "application/vnd.jupyter.widget-view+json": {
       "model_id": "f0a1a288d0854835b36b79d0d1f4d183",
       "version_major": 2,
